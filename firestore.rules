rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Secure users collection: Users can only read and write their own documents and subcollections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Match all subcollections (like /tasks) and enforce the same authentication rule
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
